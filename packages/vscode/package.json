{
  "name": "contextkit-vscode",
  "displayName": "AgentContextKit",
  "version": "0.2.0",
  "description": "Local-first AI coding agent context manager for AGENTS.md, Claude, Cursor, Copilot, Codex, MCP skills, and prompt library hygiene",
  "publisher": "VladNoskov",
  "license": "MIT",
  "icon": "media/contextkit-icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/VladNoskov/contextkit"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other",
    "Linters"
  ],
  "keywords": [
    "ai",
    "ai-agent",
    "agentcontextkit",
    "context",
    "agent-context",
    "instructions",
    "skills",
    "mcp",
    "prompt-library",
    "agents.md",
    "claude.md",
    "cursor",
    "copilot",
    "developer-tools"
  ],
  "activationEvents": [
    "onView:contextkit.sidebar",
    "onView:contextkit.setup",
    "onCommand:contextkit.scanWorkspace",
    "onCommand:contextkit.refresh",
    "onCommand:contextkit.openReport",
    "onCommand:contextkit.generateInstructions",
    "onCommand:contextkit.splitInstructionFile",
    "onCommand:contextkit.convertInstructions",
    "onCommand:contextkit.createContextPack",
    "onCommand:contextkit.openSettings",
    "onCommand:contextkit.openFile",
    "onCommand:contextkit.skillsSearch",
    "onCommand:contextkit.skillsPreview",
    "onCommand:contextkit.skillsAdd",
    "onCommand:contextkit.skillsWizard",
    "workspaceContains:**/AGENTS.md",
    "workspaceContains:**/CLAUDE.md",
    "workspaceContains:**/.cursor/rules/**",
    "workspaceContains:**/.github/copilot-instructions.md"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "contextkit.scanWorkspace",
        "title": "AgentContextKit: Scan Workspace"
      },
      {
        "command": "contextkit.refresh",
        "title": "AgentContextKit: Refresh"
      },
      {
        "command": "contextkit.openReport",
        "title": "AgentContextKit: Open Report"
      },
      {
        "command": "contextkit.generateInstructions",
        "title": "AgentContextKit: Generate Instructions"
      },
      {
        "command": "contextkit.splitInstructionFile",
        "title": "AgentContextKit: Split Instruction File"
      },
      {
        "command": "contextkit.convertInstructions",
        "title": "AgentContextKit: Convert Instructions"
      },
      {
        "command": "contextkit.createContextPack",
        "title": "AgentContextKit: Create Context Pack"
      },
      {
        "command": "contextkit.openSettings",
        "title": "AgentContextKit: Open Setup"
      },
      {
        "command": "contextkit.openFile",
        "title": "AgentContextKit: Open File"
      },
      {
        "command": "contextkit.skillsSearch",
        "title": "AgentContextKit: Search Skills"
      },
      {
        "command": "contextkit.skillsPreview",
        "title": "AgentContextKit: Preview Skill"
      },
      {
        "command": "contextkit.skillsAdd",
        "title": "AgentContextKit: Add Skill"
      },
      {
        "command": "contextkit.skillsWizard",
        "title": "AgentContextKit: Install Skills Wizard"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "contextkit",
          "title": "AgentContextKit",
          "icon": "media/contextkit-activitybar.png"
        }
      ]
    },
    "views": {
      "contextkit": [
        {
          "id": "contextkit.sidebar",
          "name": "Project Context"
        },
        {
          "id": "contextkit.setup",
          "name": "Setup",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "AgentContextKit",
      "properties": {
        "contextkit.autoScanOnOpen": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan the workspace when the extension activates."
        },
        "contextkit.autoScanOnSave": {
          "type": "boolean",
          "default": false,
          "description": "Automatically scan when instruction files are saved."
        },
        "contextkit.tokenWarningThreshold": {
          "type": "number",
          "default": 4000,
          "description": "Token count threshold for warnings."
        },
        "contextkit.tokenErrorThreshold": {
          "type": "number",
          "default": 8000,
          "description": "Token count threshold for errors."
        },
        "contextkit.include": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "description": "Additional file patterns to include."
        },
        "contextkit.exclude": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["node_modules", ".git", "dist", "build", ".next", "coverage"],
          "description": "Patterns to exclude from scanning."
        },
        "contextkit.preferredInstructionFormat": {
          "type": "string",
          "default": "agents",
          "enum": ["agents", "claude", "cursor", "copilot", "roo"],
          "description": "Preferred instruction file format."
        },
        "contextkit.defaultContextPacks": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["frontend", "backend", "database", "testing", "security", "deployment"],
          "description": "Default context packs to show in the sidebar."
        },
        "contextkit.enableDiagnostics": {
          "type": "boolean",
          "default": true,
          "description": "Enable diagnostics (warnings/errors) in instruction files."
        },
        "contextkit.enableStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show AgentContextKit status in the status bar."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsup src/extension.ts --format cjs --external vscode --clean",
    "build": "tsup src/extension.ts --format cjs --external vscode --clean",
    "watch": "tsup src/extension.ts --format cjs --external vscode --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "package": "pnpm run build && npx @vscode/vsce package --skip-license"
  },
  "dependencies": {
    "@contextkit/core": "workspace:*"
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@types/node": "^20.0.0",
    "@vscode/vsce": "^2.26.0",
    "tsup": "^8.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.4.0"
  }
}
