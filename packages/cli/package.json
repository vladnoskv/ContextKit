{
  "name": "contextkit",
  "version": "0.1.0",
  "description": "AI Coding Context Manager CLI — manage, validate, split, convert, and measure AI coding instruction files",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "contextkit": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --shims",
    "dev": "tsup src/index.ts --format esm --watch --shims",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contextkit/core": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "eslint": "^8.57.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
