{
  "name": "contextkit",
  "version": "0.2.0",
  "description": "AgentContextKit CLI — local-first AI coding agent context manager, instruction scanner, skill library, and MCP server",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "agentcontextkit": "./dist/index.js",
    "contextkit": "./dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm --clean --shims",
    "dev": "tsup src/index.ts --format esm --watch --shims",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@contextkit/core": "workspace:*",
    "@contextkit/mcp": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^1.6.0",
    "eslint": "^8.57.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.4.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
