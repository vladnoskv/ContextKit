{
  "name": "agentcontextkit",
  "version": "0.2.1",
  "private": true,
  "description": "AgentContextKit — local-first AI coding agent context manager, instruction file scanner, prompt skill library, and MCP skill server",
  "keywords": [
    "ai",
    "ai-agent",
    "agentcontextkit",
    "context",
    "agent-context",
    "instructions",
    "mcp",
    "mcp-server",
    "skills",
    "prompt-library",
    "agents.md",
    "claude.md",
    "cursor",
    "copilot",
    "developer-tools",
    "context-hygiene"
  ],
  "license": "MIT",
  "author": "Vlad Noskov",
  "repository": {
    "type": "git",
    "url": "https://github.com/VladNoskov/contextkit"
  },
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "pack:cli": "pnpm --filter contextkit pack",
    "pack:vscode": "pnpm --filter contextkit-vscode package",
    "clean": "pnpm -r clean",
    "smoke:bun": "bun packages/cli/src/index.ts scan --root examples/basic-next-app"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "devDependencies": {
    "prettier": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
